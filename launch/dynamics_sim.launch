<launch>
    <rosparam command="load" file="$(find pendulum_control)/config/topics.yaml" />

    <node pkg="pendulum_control" type="kalman_filter.py" name="kalman_filter_node_bottom" output="screen">
        <param name="calculate_gains" value="true" />
        <param name="matrices_path" value="data/matrices" />
        <param name="B_path" value="/Bcb.csv" />
        <param name="subsystem_topic" value="/bottom/y" />
        <param name="pub_topic" value="/bottom/v_sp" />
    </node>
    <node pkg="pendulum_control" type="dynamics_simulator.py" name="dynamics_simulator_node_top" output="screen">
        <param name="matrices_path" value="data/matrices" />
    </node>
</launch>
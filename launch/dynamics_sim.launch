<launch>
    <rosparam command="load" file="$(find pendulum_control)/config/param_server.yaml" />
    <include file="$(find ethercat_ros_configurator)/launch/converters.launch" />
    <!-- <include file="$(find ethercat_ros_configurator)/launch/test_motor_start.launch" /> -->

    <group ns="bottom">
        <node pkg="pendulum_control" type="dynamics_simulator.py" name="dynamics_simulator_node_bottom" output="screen"/>
        <node pkg="pendulum_control" type="kalman_filter.py" name="kalman_filter_node_bottom" output="screen">
            <param name="calculate_gains" value="true" />
        </node>
        <node pkg="pendulum_control" type="publisher.py" name="publisher_node_bottom" output="screen"/>
    </group>
    <group ns="top">
        <node pkg="pendulum_control" type="dynamics_simulator.py" name="dynamics_simulator_node_top" output="screen"/>
        <node pkg="pendulum_control" type="kalman_filter.py" name="kalman_filter_node_top" output="screen">
            <param name="calculate_gains" value="true" />
        </node>
        <node pkg="pendulum_control" type="publisher.py" name="publisher_node_top" output="screen"/>
    </group>
    <node pkg="pendulum_control" type="dashboard.py" name="dashboard_node" output="screen"/>
</launch>